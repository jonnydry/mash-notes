{
	"name": "mash-notes",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"description": "A fast, local-first scratch workbench for turning messy text and files into useful, portable results.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jonnydry/mash-notes.git"
	},
	"bugs": {
		"url": "https://github.com/jonnydry/mash-notes/issues"
	},
	"engines": {
		"node": ">=22"
	},
	"overrides": {
		"cookie": "^0.7.2"
	},
	"scripts": {
		"dev": "node scripts/sync-pdfjs-assets.mjs && vite dev",
		"build": "node scripts/sync-pdfjs-assets.mjs && vite build",
		"preview": "node scripts/serve-static.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "node scripts/sync-pdfjs-assets.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:cross-browser": "playwright test e2e/smoke.spec.ts --project=firefox --project=webkit",
		"perf:budget": "node scripts/check-performance-budget.mjs",
		"check:deploy": "node scripts/check-deployment-contract.mjs",
		"audit:security": "npm audit --audit-level=high",
		"ci": "npm run lint && npm run check && npm run audit:security && npm run build && npm run perf:budget && npm run check:deploy && npm run test && npm run test:e2e && npm run test:e2e:cross-browser"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource/fraunces": "^5.2.9",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/literata": "^5.2.8",
		"@fontsource/newsreader": "^5.2.10",
		"@fontsource/nunito-sans": "^5.2.7",
		"@fontsource/source-sans-3": "^5.2.9",
		"@fontsource/source-serif-4": "^5.2.9",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26",
		"@vite-pwa/sveltekit": "^1.1.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.7.0",
		"jszip": "^3.10.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@pdf-lib/fontkit": "^1.1.1",
		"dexie": "^4.4.4",
		"docx": "^9.7.1",
		"gifuct-js": "^2.1.2",
		"mammoth": "^1.12.0",
		"marked": "^18.0.6",
		"minisearch": "^7.2.0",
		"pdf-lib": "^1.17.1",
		"pdfjs-dist": "^6.1.200",
		"vite-plugin-pwa": "^1.3.0"
	}
}
